<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarketLine</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)


    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
</head>

<body>
    <div class="ml-page">

        <header class="ml-navbar">
            <div class="ml-navbar-inner">

                <button class="ml-hamburger" id="mlHamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mlNavLinks">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <a class="ml-brand" href="/Dashboard">
                    <svg class="ml-brand-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 17l6-6 4 4 8-8" stroke="url(#g)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <defs><linearGradient id="g" x1="0" y1="0" x2="24" y2="0"><stop stop-color="#ffd76a"/><stop offset="1" stop-color="#ff8a4c"/></linearGradient></defs>
                    </svg>
                    <span>MarketLine</span>
                </a>

                <nav class="ml-nav-links" id="mlNavLinks">
                    @{
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    }
                    <a href="/Dashboard" class="ml-nav-item @(currentController == "Dashboard" ? "active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5" /><path d="M5.5 10v9a1 1 0 0 0 1 1H9a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h2.5a1 1 0 0 0 1-1v-9" /></svg>
                        <span>Home</span>
                    </a>
                    <a href="#" class="ml-nav-item">
                        <svg viewBox="0 0 24 24"><path d="M12 3l7 3v6c0 4.5-3 7.7-7 9-4-1.3-7-4.5-7-9V6l7-3Z" /><path d="m9.5 12 2 2 3.5-3.5" /></svg>
                        <span>Privacy</span>
                    </a>
                    <a href="/Sales/Create" class="ml-nav-item">
                        <svg viewBox="0 0 24 24"><path d="M12 3 2.5 8v8L12 21l9.5-5V8L12 3Z" /><path d="M12 8v8M8 12h8" /></svg>
                        <span>Add Sales</span>
                    </a>
                    <a href="/Goods" class="ml-nav-item @(currentController == "Goods" ? "active" : "")">
                        <svg viewBox="0 0 24 24"><rect x="3" y="7" width="18" height="14" rx="2" /><path d="M8 7V5a4 4 0 0 1 8 0v2" /></svg>
                        <span>Add Goods</span>
                    </a>
                    <a href="/Customers" class="ml-nav-item">
                        <svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3.2" /><path d="M3.5 20c0-3.3 2.5-6 5.5-6s5.5 2.7 5.5 6" /><circle cx="17.5" cy="9" r="2.6" /><path d="M14.5 20c.3-2.7 2.1-4.7 4.4-4.7 1.8 0 3.4 1.2 4.1 3" /></svg>
                        <span>Customers Record</span>
                    </a>
                    <a href="/Account/Profiles" class="ml-nav-item">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                        <span>Profiles</span>
                    </a>
                </nav>

                <div class="ml-nav-right">

                    <!-- 💰 PAYMENT ICON -->
                    <button class="ml-coin-badge" id="paymentToggle" title="Payments Received" type="button">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="6" /><circle cx="8" cy="15" r="6" /><circle cx="16" cy="15" r="6" /></svg>
                        <span class="ml-badge-count" id="paymentCount" style="display:none;">0</span>
                    </button>

                    <!-- 🔔 NOTIFICATION BELL -->
                    <button class="ml-bell-badge" id="notifToggle" title="Notifications" type="button">
                        <svg viewBox="0 0 24 24"><path d="M12 3a5 5 0 0 0-5 5v3.2c0 .6-.2 1.1-.6 1.6L5 15.5c-.6.7-.1 1.8.8 1.8h12.4c.9 0 1.4-1.1.8-1.8l-1.4-2.7a2.5 2.5 0 0 1-.6-1.6V8a5 5 0 0 0-5-5Z" /><path d="M9.5 19a2.5 2.5 0 0 0 5 0" /></svg>
                        <span class="ml-badge-count" id="notifCount" style="display:none;">0</span>
                    </button>

                    <!-- Dropdown for Notifications (Orders) -->
                    <div class="ml-dropdown" id="notifDropdown">
                        <div class="ml-dropdown-header">📦 Recent Orders</div>
                        <div id="notifList"></div>
                    </div>

                    <!-- Dropdown for Payments -->
                    <div class="ml-dropdown" id="paymentDropdown">
                        <div class="ml-dropdown-header">💰 Payments Received</div>
                        <div id="paymentList"></div>
                    </div>
                </div>
            </div>
        </header>

        <main class="ml-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Starts Idle Page after 2 minutes of cashier inactivity -->
    <script src="~/js/idle-timer.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        async function loadNotifications() {
        try {
        const res = await fetch('/Notification/GetOrders');
        const data = await res.json();
        const orders = data.orders;
        const unread = data.unreadCount;

        const badge = document.getElementById('notifCount');
        if (unread > 0) {
        badge.textContent = unread;
        badge.style.display = 'inline-block';
        } else {
        badge.style.display = 'none';
        }

        const list = document.getElementById('notifList');
        if (orders.length === 0) {
        list.innerHTML = '<div class="ml-dropdown-empty">No orders yet</div>';
        } else {
        list.innerHTML = orders.map(o => `
        <a href="/Notification/OrderDetails/${o.id}" class="ml-dropdown-item">
        <div>
        <strong>${o.name} ${o.isNew ? '<span style="color:#ef4444;font-size:10px;">● NEW</span>' : ''}</strong>
        <small>${o.date} · ${o.status}</small>
        </div>
        <span class="amt">₦${Number(o.total).toLocaleString('en-NG')}</span>
        </a>`).join('');
        }
        } catch(e) { console.log('Notif fetch failed', e); }
        }

        async function loadPayments() {
        try {
        const res = await fetch('/Notification/GetPayments');
        const data = await res.json();
        const payments = data.payments;
        const unread = data.unreadCount;

        const badge = document.getElementById('paymentCount');
        if (unread > 0) {
        badge.textContent = unread;
        badge.style.display = 'inline-block';
        } else {
        badge.style.display = 'none';
        }

        const list = document.getElementById('paymentList');
        if (payments.length === 0) {
        list.innerHTML = '<div class="ml-dropdown-empty">No payments yet</div>';
        } else {
        list.innerHTML = payments.map(p => `
        <a href="/Notification/PaymentReceipt/${p.id}" class="ml-dropdown-item">
        <div>
        <strong>${p.name} ${p.isNew ? '<span style="color:#ef4444;font-size:10px;">● NEW</span>' : ''}</strong>
        <small>${p.date} · ${p.method}</small>
        </div>
        <span class="amt">₦${Number(p.total).toLocaleString('en-NG')}</span>
        </a>`).join('');
        }
        } catch(e) { console.log('Payment fetch failed', e); }
        }

        // Mark as seen when opening dropdowns
        async function markOrdersSeen() {
        await fetch('/Notification/MarkOrdersSeen', { method: 'POST' });
        document.getElementById('notifCount').style.display = 'none';
        }

        async function markPaymentsSeen() {
        await fetch('/Notification/MarkPaymentsSeen', { method: 'POST' });
        document.getElementById('paymentCount').style.display = 'none';
        }

        document.getElementById('notifToggle').addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('paymentDropdown').classList.remove('show');
        const dropdown = document.getElementById('notifDropdown');
        dropdown.classList.toggle('show');
        if (dropdown.classList.contains('show')) markOrdersSeen();
        });

        document.getElementById('paymentToggle').addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('notifDropdown').classList.remove('show');
        const dropdown = document.getElementById('paymentDropdown');
        dropdown.classList.toggle('show');
        if (dropdown.classList.contains('show')) markPaymentsSeen();
        });

        document.addEventListener('click', () => {
        document.getElementById('notifDropdown').classList.remove('show');
        document.getElementById('paymentDropdown').classList.remove('show');
        });

        loadNotifications();
        loadPayments();

        setInterval(() => { loadNotifications(); loadPayments(); }, 15000);
    </script>
</body>
</html>
