@model List<MarketLine.Models.Product>
@{
    ViewData["Title"] = "Add Goods";
}

@Html.AntiForgeryToken()

<section class="goods-header">
    <h1><span class="goods-brand">PRESTIGE</span></h1>
    <h2 class="goods-subbrand">SOFT DRINK STORE</h2>
    <p class="goods-tagline">
        Dealer in all kinds of soft drinks such as Coke, Fearless, Malt, Viju Milk, Yogurt etc.
        Both Wholesale and Retail.
    </p>
</section>

<section class="goods-toolbar">
    <h3>Gallery</h3>
    <button type="button" class="ml-go-btn goods-add-btn" id="btnOpenAdd">+ Add New Item</button>
</section>

<section class="goods-grid" id="goodsGrid">
    @if (!Model.Any())
    {
        <p class="goods-empty" id="goodsEmptyMsg">No items yet. Click "Add New Item" to get started.</p>
    }
    @foreach (var item in Model)
    {
        <div class="goods-card" data-id="@item.Id" data-barcode="@item.Barcode">
            <div class="goods-card-actions">
                <button type="button" class="icon-btn edit-btn" title="Edit" aria-label="Edit item">
                    <svg viewBox="0 0 24 24"><path d="M4 20h4l10-10-4-4L4 16v4Z" /><path d="m14.5 5.5 4 4" /></svg>
                </button>
                <button type="button" class="icon-btn delete-btn" title="Delete" aria-label="Delete item">
                    <svg viewBox="0 0 24 24"><path d="M4 7h16" /><path d="M9 7V4h6v3" /><path d="M6 7l1 13h10l1-13" /><path d="M10 11v6M14 11v6" /></svg>
                </button>
            </div>

            <div class="goods-card-image">
                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@item.ImagePath" alt="@item.Name" />
                }
                else
                {
                    <svg viewBox="0 0 24 24" class="goods-placeholder-icon"><path d="M4 16.5 8.5 12l3 3 5-6L21 16.5" /><rect x="3" y="4" width="18" height="16" rx="2.5" /></svg>
                }
            </div>

            <div class="goods-card-body">
                <div class="goods-card-title">@item.Name</div>
                <div class="goods-card-price">₦@item.Price.ToString("N0")</div>
            </div>
        </div>
    }
</section>

<!-- Add / Edit modal -->
<div class="ml-modal-overlay" id="itemModalOverlay">
    <div class="ml-modal">
        <h3 id="itemModalTitle">Add New Item</h3>
        <form id="itemForm">
            <input type="hidden" id="itemId" value="0" />

            <label class="ml-field">
                <span>Item name</span>
                <input type="text" id="itemName" maxlength="150" required placeholder="e.g. Coca-Cola 50cl" />
            </label>

            <label class="ml-field">
                <span>Price</span>
                <input type="number" id="itemPrice" min="0" step="0.01" required placeholder="0.00" />
            </label>

            <label class="ml-field">
                <span>Barcode <span class="ml-field-hint">(optional — enables camera scan on the Sales page)</span></span>
                <input type="text" id="itemBarcode" maxlength="64" placeholder="e.g. 6001067004013" />
            </label>

            <label class="ml-field">
                <span>Image <span class="ml-field-hint" id="imageHint">(optional)</span></span>
                <input type="file" id="itemImage" accept=".jpg,.jpeg,.png,.webp,.gif" />
            </label>

            <p class="ml-modal-error" id="itemFormError"></p>

            <div class="ml-modal-actions">
                <button type="button" class="ml-btn-secondary" id="btnCancelItem">Cancel</button>
                <button type="submit" class="ml-go-btn" id="btnSaveItem">Save</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="ml-modal-overlay" id="deleteModalOverlay">
    <div class="ml-modal ml-modal-sm">
        <h3>Delete item?</h3>
        <p class="ml-modal-text">
            Are you sure you want to delete "<span id="deleteItemName"></span>"?
            This cannot be undone.
        </p>
        <div class="ml-modal-actions">
            <button type="button" class="ml-btn-secondary" id="btnCancelDelete">Cancel</button>
            <button type="button" class="ml-btn-danger" id="btnConfirmDelete">Delete</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/goods.js" asp-append-version="true"></script>
}
