@{
    ViewData["Title"] = "Add Sales";
}

@section Styles {
    <link rel="stylesheet" href="~/css/sales.css" asp-append-version="true" />

    <!-- AI Futuristic Vision CSS Styles -->
    <style>
        .ai-video-container {
            position: relative;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
            border-radius: 16px;
            overflow: hidden;
            border: 2px solid #7ed957;
            box-shadow: 0 0 25px rgba(126, 217, 87, 0.4);
            background: #000;
        }

        #cameraVideo {
            width: 100%;
            height: auto;
            display: block;
            transform: scaleX(1); /* Flip if using front camera is handled dynamically in JS */
        }

        /* Neon Laser Scanner Line */
        .ai-scanner-laser {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(to bottom, transparent, #7ed957, transparent);
            box-shadow: 0 0 15px #7ed957, 0 0 8px rgba(126, 217, 87, 0.8);
            animation: aiScanLaser 2.2s infinite linear;
            z-index: 10;
        }

        @@keyframes aiScanLaser {
            0% {
                top: 0%;
            }

            50% {
                top: 100%;
            }

            100% {
                top: 0%;
            }
        }

        /* Confidence Match Bar */
        .ai-confidence-bar-container {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            height: 12px;
            margin-top: 15px;
            overflow: hidden;
            position: relative;
        }

        #aiConfidenceProgress {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #ffd76a, #7ed957);
            box-shadow: 0 0 10px #7ed957;
            transition: width 0.1s ease-out;
        }

        .ai-status-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #ff6b6b;
            margin-right: 6px;
            box-shadow: 0 0 8px #ff6b6b;
        }

        .ai-status-active {
            background: #7ed957 !important;
            box-shadow: 0 0 12px #7ed957 !important;
            animation: pulseActive 1s infinite alternate;
        }

        @@keyframes pulseActive {
            from {
                transform: scale(1);
                opacity: 0.7;
            }

            to {
                transform: scale(1.3);
                opacity: 1;
            }
        }
    </style>
}

@Html.AntiForgeryToken()

<div class="invoice-page">

    <button type="button" class="camera-toggle-btn" id="btnOpenCamera" title="Scan item via AI Camera" aria-label="Scan item via AI Camera">
        <svg viewBox="0 0 24 24"><path d="M4 8a2 2 0 0 1 2-2h1.2l.9-1.5A1.5 1.5 0 0 1 9.4 4h5.2a1.5 1.5 0 0 1 1.3.75L16.8 6H18a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" /><circle cx="12" cy="13" r="3.4" /></svg>
    </button>

    <button type="button" class="goods-toggle-btn" id="btnOpenGoods">
        <svg viewBox="0 0 24 24"><rect x="3" y="7" width="18" height="14" rx="2" /><path d="M8 7V5a4 4 0 0 1 8 0v2" /></svg>
        Goods
    </button>

    <div class="invoice-header">
        <h1>PRESTIGE</h1>
        <h2>SOFT DRINK STORE</h2>
        <p>Dealer in all kinds of soft drinks such as Coke, Fearless, Malt, Viju Milk, Yogurt etc. Both Wholesale and Retail.</p>
    </div>

    <div class="store-meta">
        <p>📍 Formal Dave Mercy Clinic, Idiagbo, Jebba, Kwara State.</p>
        <p>📞 08000000000</p>
    </div>

    <div class="customer-fields">
        <div class="glow-field" id="customerNameField">
            <div class="field-label-row">
                <span>Customer Name</span>
                <span class="invoice-datetime" id="invoiceDateTime"></span>
            </div>
            <input type="text" id="customerName" autocomplete="off" />
            <div class="customer-suggestions" id="customerSuggestions"></div>
        </div>
        <div class="glow-field">
            <span>Customer Address</span>
            <input type="text" id="customerAddress" autocomplete="off" />
        </div>
        <div class="glow-field" id="customerPhoneField">
            <span>Customer Phone Number</span>
            <input type="text" id="customerPhone" autocomplete="off" />
            <div class="customer-suggestions" id="phoneSuggestions"></div>
        </div>
    </div>

    <div class="invoice-title">
        <h2>SALES INVOICE</h2>
    </div>

    <div class="manual-row-bar">
        <button type="button" id="btnAddManualRow">+ Add item manually</button>
    </div>
    <div class="invoice-table-scroll">
        <table class="invoice-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Description</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Total Price</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody id="invoiceBody">
                <!-- rows added here by JS -->
            </tbody>
        </table>
    </div>
    <div class="amount-words-box">
        <span>Amount in words:</span>
        <strong id="amountInWords">Zero Naira Only</strong>
    </div>

    <div class="invoice-footer">
        <div class="invoice-note">
            RECEIVED THIS GOODS IN GOOD CONDITION<br />
            NO REFUND OF MONEY AFTER PAYMENT
        </div>
        <div class="invoice-thanks">
            Thanks for your patronage
        </div>
        <div class="total-box">
            <span>TOTAL PRICE</span>
            <strong id="grandTotal">₦0</strong>
        </div>
    </div>

    <div class="invoice-signatures">
        <div class="invoice-signature">
            <div class="sig-line"></div>
            Customer's Sign.
        </div>
        <div class="invoice-signature">
            <div class="sig-line"></div>
            Manager's Sign.
        </div>
    </div>
    <div class="invoice-save-bar">
        <button type="button" id="btnPreviewSale">Preview Sale</button>
        <p class="invoice-save-msg" id="saveMsg"></p>
    </div>

    <!-- Goods slide-out drawer -->
    <div class="goods-drawer-overlay" id="goodsDrawerOverlay">
        <aside class="goods-drawer">
            <div class="goods-drawer-header">
                <h3>Select Items</h3>
            </div>
            <div class="goods-drawer-search">
                <input type="text" id="goodsSearchInput" placeholder="Search item…" autocomplete="off" />
                <button type="button" class="drawer-close-btn" id="btnCloseGoods" aria-label="Close">&times;</button>
            </div>
            <div class="goods-drawer-list" id="goodsDrawerList">
                <div class="goods-drawer-empty">Loading…</div>
            </div>
        </aside>
    </div>

    <!-- Camera picker + AI scanner modal -->
    <div class="ml-modal-overlay" id="cameraModalOverlay">
        <div class="ml-modal camera-modal">
            <div id="cameraChooseStep">
                <h3>Scan item via AI Vision</h3>
                <p class="ml-modal-text">Select which camera you want to use.</p>
                <div class="camera-choice-row">
                    <button type="button" class="camera-choice-btn" id="btnUseFrontCamera">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" /><circle cx="12" cy="12" r="3" /></svg>
                        Front
                    </button>
                    <button type="button" class="camera-choice-btn" id="btnUseBackCamera">
                        <svg viewBox="0 0 24 24"><path d="M4 8a2 2 0 0 1 2-2h1.2l.9-1.5A1.5 1.5 0 0 1 9.4 4h5.2a1.5 1.5 0 0 1 1.3.75L16.8 6H18a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" /><circle cx="12" cy="13" r="3.4" /></svg>
                        Back
                    </button>
                </div>
                <div class="ml-modal-actions">
                    <button type="button" class="ml-btn-secondary" id="btnCancelCamera">Cancel</button>
                </div>
            </div>

            <div id="cameraScanStep" style="display:none;">
                <h3>Aim camera at the product</h3>

                <div class="ai-video-container">
                    <div class="ai-scanner-laser"></div>
                    <video id="cameraVideo" autoplay playsinline muted></video>
                </div>

                <div class="ai-confidence-bar-container">
                    <div id="aiConfidenceProgress"></div>
                </div>

                <p class="ml-modal-text" id="cameraStatus" style="font-weight: 500; margin-top: 15px;">
                    <span class="ai-status-indicator" id="aiIndicator"></span>
                    Initializing AI models...
                </p>
                <div class="ml-modal-actions">
                    <button type="button" class="ml-btn-secondary" id="btnStopCamera">Stop</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Load TensorFlow.js and MobileNet model CDN with escaped razor symbols -->
    <script src="https://cdn.jsdelivr.net/npm/@@tensorflow/tfjs@4.20.0/dist/tf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@tensorflow-models/mobilenet@2.1.1/dist/mobilenet.min.js"></script>

    <script src="~/js/sales.js" asp-append-version="true"></script>

    <!-- AI Scanner Operations Script -->
    <script>
        let aiModel = null;
        let aiProductsDb = [];
        let isModelLoading = false;
        let isCameraScanning = false;
        let activeStream = null;
        let scanningLock = false;
        let consecutiveMatches = 0;
        let lastMatchedId = null;

        // ===== WEB AUDIO API - SCANNER BEEP =====
        function playScanBeep() {
        try {
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const oscillator = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();

        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);

        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(950, audioCtx.currentTime); // High pitch scan beep
        gainNode.gain.setValueAtTime(0.25, audioCtx.currentTime);

        oscillator.start();
        oscillator.stop(audioCtx.currentTime + 0.11); // Short 110ms beep
        } catch (e) {
        console.warn("Audio context blocked by user interaction gesture.");
        }
        }

        // ===== INITIALIZE AI ENGINE AND EXTRACT DATABASE FINGERPRINTS =====
        async function initializeAIVision() {
        if (aiModel || isModelLoading) return;
        isModelLoading = true;
        updateStatusIndicator(false, "Loading AI Vision model...");

        try {
        // Load TensorFlow MobileNet model
        aiModel = await mobilenet.load({ version: 1, alpha: 1.0 });
        updateStatusIndicator(false, "Loading product catalog...");

        // Fetch current products from database
        const response = await fetch('/Goods/Search');
        const products = await response.json();

        updateStatusIndicator(false, "Scanning database product files...");

        // Loop through and extract vectors of images
        for (let product of products) {
        if (product.imagePath) {
        try {
        const fingerprint = await extractImageFingerprint(product.imagePath);
        aiProductsDb.push({
        id: product.id,
        name: product.name,
        price: product.price,
        fingerprint: fingerprint
        });
        } catch (imgError) {
        console.error(`Failed to index image for ${product.name}:`, imgError);
        }
        }
        }

        isModelLoading = false;
        updateStatusIndicator(true, `AI Active. Indexed ${aiProductsDb.length} products.`);
        } catch (error) {
        console.error("AI Initialization failed:", error);
        isModelLoading = false;
        updateStatusIndicator(false, "AI failed to initialize.");
        }
        }

        // Helper to load image securely via CORS and extract features
        function extractImageFingerprint(src) {
        return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "anonymous"; // Essential to read Cloudinary pixels securely
        img.src = src;

        img.onload = async () => {
        try {
        // Extract activation layers up to the MobileNet bottleneck layer (raw features)
        const activation = aiModel.infer(img, true);
        const features = await activation.data();
        activation.dispose(); // Avoid memory leaks
        resolve(features);
        } catch (e) {
        reject(e);
        }
        };
        img.onerror = (err) => reject(img.src + " load failed");
        });
        }

        function updateStatusIndicator(isActive, text) {
        const ind = document.getElementById("aiIndicator");
        const txt = document.getElementById("cameraStatus");
        if (ind && txt) {
        txt.innerHTML = `<span class="ai-status-indicator ${isActive ? 'ai-status-active' : ''}" id="aiIndicator"></span> ${text}`;
        }
        }

        // ===== START CAMERA RUNTIME =====
        async function startCamera(facingMode) {
        await initializeAIVision();

        const video = document.getElementById("cameraVideo");
        const chooseStep = document.getElementById("cameraChooseStep");
        const scanStep = document.getElementById("cameraScanStep");

        try {
        activeStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: facingMode, width: { ideal: 640 }, height: { ideal: 480 } }
        });

        video.srcObject = activeStream;
        chooseStep.style.display = "none";
        scanStep.style.display = "block";
        isCameraScanning = true;

        requestAnimationFrame(processCameraFrame);
        } catch (err) {
        alert("Unable to open camera: " + err.message);
        stopCamera();
        }
        }

        // ===== COSINE SIMILARITY MATH MATCHER =====
        function calculateSimilarity(vecA, vecB) {
        let dotProduct = 0.0;
        let normA = 0.0;
        let normB = 0.0;
        for (let i = 0; i < vecA.length; i++) {
        dotProduct += vecA[i] * vecB[i];
        normA += vecA[i] * vecA[i];
        normB += vecB[i] * vecB[i];
        }
        return dotProduct / (Math.sqrt(normA) * Math.sqrt(normB));
        }

        // ===== CORE FRAME PROCESSING LOOP =====
        async function processCameraFrame() {
        if (!isCameraScanning || scanningLock) return;

        const video = document.getElementById("cameraVideo");
        const confBar = document.getElementById("aiConfidenceProgress");

        if (video.readyState === video.HAVE_ENOUGH_DATA) {
        try {
        // Extract features from live frame
        const frameActivation = aiModel.infer(video, true);
        const frameFingerprint = await frameActivation.data();
        frameActivation.dispose();

        let bestMatch = null;
        let highestScore = 0.0;

        // Compute matches against database
        for (let item of aiProductsDb) {
        const score = calculateSimilarity(frameFingerprint, item.fingerprint);
        if (score > highestScore) {
        highestScore = score;
        bestMatch = item;
        }
        }

        // Update UI visual feedback elements
        confBar.style.width = `${highestScore * 100}%`;

        if (highestScore > 0.86) {
        updateStatusIndicator(true, `Matching: <strong>${bestMatch.name}</strong> (${Math.round(highestScore * 100)}%)`);

        if (lastMatchedId === bestMatch.id) {
        consecutiveMatches++;
        } else {
        consecutiveMatches = 1;
        lastMatchedId = bestMatch.id;
        }

        // Product matched consistently across 3 frames (stabilization)
        if (consecutiveMatches >= 3) {
        triggerProductMatch(bestMatch);
        }
        } else {
        consecutiveMatches = 0;
        updateStatusIndicator(true, "Searching for product...");
        }

        } catch (e) {
        console.error("Frame processing failed:", e);
        }
        }

        if (isCameraScanning) {
        // Keep processing next frame roughly every 150ms to keep CPU usage balanced
        setTimeout(() => {
        requestAnimationFrame(processCameraFrame);
        }, 150);
        }
        }

        // ===== TRIGGER MATCH AND SIMULATE ROW ADDITION =====
        function triggerProductMatch(product) {
        scanningLock = true;
        isCameraScanning = false;

        playScanBeep();
        updateStatusIndicator(true, `✅ ADDED: <strong>${product.name}</strong>!`);

        // Build virtual button simulation to let sales.js trigger its internal row additions perfectly!
        const virtualContainer = document.createElement("div");
        virtualContainer.className = "goods-item drawer-item";
        virtualContainer.style.display = "none";

        const virtualBtn = document.createElement("button");
        virtualBtn.className = "btn-add drawer-add-btn";
        virtualBtn.dataset.id = product.id;
        virtualBtn.dataset.name = product.name;
        virtualBtn.dataset.price = product.price;

        virtualContainer.appendChild(virtualBtn);
        document.body.appendChild(virtualContainer);

        // Dispatch click event that bubbles up
        const clickEvent = new MouseEvent('click', { bubbles: true, cancelable: true });
        virtualBtn.dispatchEvent(clickEvent);

        // Cleanup DOM
        virtualContainer.remove();

        // Set visual cooldown before unlocking scanning again
        setTimeout(() => {
        scanningLock = false;
        isCameraScanning = true;
        consecutiveMatches = 0;
        lastMatchedId = null;
        const confBar = document.getElementById("aiConfidenceProgress");
        if (confBar) confBar.style.width = '0%';
        requestAnimationFrame(processCameraFrame);
        }, 2500); // 2.5s cooldown
        }

        function stopCamera() {
        isCameraScanning = false;
        if (activeStream) {
        activeStream.getTracks().forEach(track => track.stop());
        activeStream = null;
        }
        document.getElementById("cameraScanStep").style.display = "none";
        document.getElementById("cameraChooseStep").style.display = "block";
        document.getElementById("cameraModalOverlay").classList.remove("show");

        const confBar = document.getElementById("aiConfidenceProgress");
        if (confBar) confBar.style.width = '0%';
        }

        // ===== HOOK INTERFACE BUTTONS =====
        document.addEventListener("DOMContentLoaded", () => {
        // Trigger pre-loading and indexing when page completes load to avoid waiting later
        setTimeout(initializeAIVision, 1000);

        // Hijack barcode buttons in sales.js and direct them to AI Vision Engine
        const btnOpen = document.getElementById("btnOpenCamera");
        const btnCancel = document.getElementById("btnCancelCamera");
        const btnStop = document.getElementById("btnStopCamera");
        const btnFront = document.getElementById("btnUseFrontCamera");
        const btnBack = document.getElementById("btnUseBackCamera");

        if (btnOpen) {
        btnOpen.addEventListener("click", (e) => {
        e.stopImmediatePropagation(); // Stops old barcode scanner actions
        document.getElementById("cameraModalOverlay").classList.add("show");
        });
        }

        if (btnFront) {
        btnFront.addEventListener("click", () => startCamera("user"));
        }

        if (btnBack) {
        btnBack.addEventListener("click", () => startCamera("environment"));
        }

        if (btnStop) {
        btnStop.addEventListener("click", stopCamera);
        }

        if (btnCancel) {
        btnCancel.addEventListener("click", stopCamera);
        }
        });
    </script>
}