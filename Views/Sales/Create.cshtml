@{
    ViewData["Title"] = "Add Sales";
}

@section Styles {
    <link rel="stylesheet" href="~/css/sales.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="invoice-page">

    <button type="button" class="camera-toggle-btn" id="btnOpenCamera" title="Scan item barcode" aria-label="Scan item barcode">
        <svg viewBox="0 0 24 24"><path d="M4 8a2 2 0 0 1 2-2h1.2l.9-1.5A1.5 1.5 0 0 1 9.4 4h5.2a1.5 1.5 0 0 1 1.3.75L16.8 6H18a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" /><circle cx="12" cy="13" r="3.4" /></svg>
    </button>

    <button type="button" class="goods-toggle-btn" id="btnOpenGoods">
        <svg viewBox="0 0 24 24"><rect x="3" y="7" width="18" height="14" rx="2" /><path d="M8 7V5a4 4 0 0 1 8 0v2" /></svg>
        Goods
    </button>

    <div class="invoice-header">
        <h1>PRESTIGE</h1>
        <h2>SOFT DRINK STORE</h2>
        <p>Dealer in all kinds of soft drinks such as Coke, Fearless, Malt, Viju Milk, Yogurt etc. Both Wholesale and Retail.</p>
    </div>

    <div class="store-meta">
        <p>📍 Formal Dave Mercy Clinic, Idiagbo, Jebba, Kwara State.</p>
        <p>📞 08000000000</p>
    </div>

    <div class="customer-fields">
        <div class="glow-field" id="customerNameField">
            <div class="field-label-row">
                <span>Customer Name</span>
                <span class="invoice-datetime" id="invoiceDateTime"></span>
            </div>
            <input type="text" id="customerName" autocomplete="off" />
            <div class="customer-suggestions" id="customerSuggestions"></div>
        </div>
        <div class="glow-field">
            <span>Customer Address</span>
            <input type="text" id="customerAddress" autocomplete="off" />
        </div>
        <div class="glow-field" id="customerPhoneField">
            <span>Customer Phone Number</span>
            <input type="text" id="customerPhone" autocomplete="off" />
            <div class="customer-suggestions" id="phoneSuggestions"></div>
        </div>
    </div>

    <div class="invoice-title">
        <h2>SALES INVOICE</h2>
    </div>

    <div class="manual-row-bar">
        <button type="button" id="btnAddManualRow">+ Add item manually</button>
    </div>
    <div class="invoice-table-scroll">
        <table class="invoice-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Description</th>
                    <th>Quantity</th>
                    <th>Unit Price</th>
                    <th>Total Price</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody id="invoiceBody">
                <!-- rows added here by JS: from the Goods drawer, camera scan, or manually -->
            </tbody>
        </table>
    </div>
    <div class="amount-words-box">
        <span>Amount in words:</span>
        <strong id="amountInWords">Zero Naira Only</strong>
    </div>

    <div class="invoice-footer">
        <div class="invoice-note">
            RECEIVED THIS GOODS IN GOOD CONDITION<br />
            NO REFUND OF MONEY AFTER PAYMENT
        </div>
        <div class="invoice-thanks">
            Thanks for your patronage
        </div>
        <div class="total-box">
            <span>TOTAL PRICE</span>
            <strong id="grandTotal">₦0</strong>
        </div>
    </div>

    <div class="invoice-signatures">
        <div class="invoice-signature">
            <div class="sig-line"></div>
            Customer's Sign.
        </div>
        <div class="invoice-signature">
            <div class="sig-line"></div>
            Manager's Sign.
        </div>
    </div>
    <div class="invoice-save-bar">
        <button type="button" id="btnPreviewSale">Preview Sale</button>
        <p class="invoice-save-msg" id="saveMsg"></p>
    </div>

<!-- Goods slide-out drawer -->
<div class="goods-drawer-overlay" id="goodsDrawerOverlay">
    <aside class="goods-drawer">
        <div class="goods-drawer-header">
            <h3>Select Items</h3>
        </div>
        <div class="goods-drawer-search">
            <input type="text" id="goodsSearchInput" placeholder="Search item…" autocomplete="off" />
            <button type="button" class="drawer-close-btn" id="btnCloseGoods" aria-label="Close">&times;</button>
        </div>
        <div class="goods-drawer-list" id="goodsDrawerList">
            <div class="goods-drawer-empty">Loading…</div>
        </div>
    </aside>
 </div>

<!-- Camera picker + scanner modal -->
<div class="ml-modal-overlay" id="cameraModalOverlay">
    <div class="ml-modal camera-modal">
        <div id="cameraChooseStep">
            <h3>Scan an item</h3>
            <p class="ml-modal-text">Choose which camera to use.</p>
            <div class="camera-choice-row">
                <button type="button" class="camera-choice-btn" id="btnUseFrontCamera">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" /><circle cx="12" cy="12" r="3" /></svg>
                    Front
                </button>
                <button type="button" class="camera-choice-btn" id="btnUseBackCamera">
                    <svg viewBox="0 0 24 24"><path d="M4 8a2 2 0 0 1 2-2h1.2l.9-1.5A1.5 1.5 0 0 1 9.4 4h5.2a1.5 1.5 0 0 1 1.3.75L16.8 6H18a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" /><circle cx="12" cy="13" r="3.4" /></svg>
                    Back
                </button>
            </div>
            <div class="ml-modal-actions">
                <button type="button" class="ml-btn-secondary" id="btnCancelCamera">Cancel</button>
            </div>
        </div>

        <div id="cameraScanStep" style="display:none;">
            <h3>Point camera at the item's barcode</h3>
            <video id="cameraVideo" autoplay playsinline muted></video>
            <p class="ml-modal-text" id="cameraStatus">Looking for a barcode…</p>
            <div class="ml-modal-actions">
                <button type="button" class="ml-btn-secondary" id="btnStopCamera">Stop</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/sales.js" asp-append-version="true"></script>
}
