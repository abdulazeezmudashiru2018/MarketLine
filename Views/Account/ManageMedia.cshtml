@model IEnumerable<MarketLine.Models.LandingMedia>
@{
    ViewData["Title"] = "Manage Media";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="manage-page">
    <h1>🎬 Manage Landing Page Media</h1>
    <p style="color:#6b7280;">Upload images or videos to display on the login page slideshow.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-error">@TempData["Error"]</div>
    }

    <form asp-action="UploadMedia" method="post" enctype="multipart/form-data" class="upload-form">
        <input type="file" name="file" accept="image/*,video/*" required />
        <button type="submit" class="btn-upload">📤 Upload</button>
    </form>

    <h2 style="margin-top:30px;">Existing Media</h2>
    <div class="media-grid">
        @foreach (var m in Model)
        {
            <div class="media-item">
                @if (m.MediaType == "video")
                {
                    <video src="@m.FilePath" controls></video>
                }
                else
                {
                    <img src="@m.FilePath" alt="Media" />
                }
                <p>@m.UpdatedAt.ToString("MMM dd, yyyy")</p>
                <form asp-action="DeleteMedia" method="post" style="display:inline;">
                    <input type="hidden" name="id" value="@m.Id" />
                    <button type="submit" class="btn-delete" onclick="return confirm('Delete this media?')">🗑️ Delete</button>
                </form>
            </div>
        }
    </div>
</div>