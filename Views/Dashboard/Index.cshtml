@model MarketLine.Models.DashboardViewModel
@using System.Linq
@{
    ViewData["Title"] = "Dashboard";
    ViewBag.NotificationCount = Model.NotificationCount;
}

<!-- ✨ Safe Custom Embedded Styles to preserve your external site.css unmodified -->
<style>
    /* Floating bonus wheel: does not affect dashboard layout */
    .ml-bonus-wheel-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 10;
    }

    #bonusWheelSvg {
        position: absolute;
        width: 150px;
        height: 150px;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        opacity: 0.96;
        pointer-events: auto;
        filter: drop-shadow(0 0 12px rgba(34, 197, 94, 0.85));
        transition: transform 0.25s ease, filter 0.25s ease;
    }

    .ml-chart:hover #bonusWheelSvg {
        transform: translate(-50%, -50%) scale(1.06);
        filter: drop-shadow(0 0 22px rgba(74, 222, 128, 1));
    }

    /* Each of the 12 customer sections */
    .ml-wheel-slice {
        stroke: #22c55e;
        stroke-width: 1.6;
        cursor: pointer;
        transition: fill 0.2s ease, stroke 0.2s ease;
    }

        .ml-wheel-slice:hover {
            fill: rgba(34, 197, 94, 0.70) !important;
            stroke: #bbf7d0 !important;
            stroke-width: 2.5;
        }

    .ml-wheel-text {
        fill: #ffffff;
        font-family: "Segoe UI", sans-serif;
        font-size: 11px;
        font-weight: 800;
        text-anchor: middle;
        dominant-baseline: middle;
        pointer-events: none;
        paint-order: stroke;
        stroke: #0f172a;
        stroke-width: 2px;
        stroke-linejoin: round;
    }

    .ml-wheel-center-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 56px;
        height: 56px;
        transform: translate(-50%, -50%);
        border: 2px solid #4ade80;
        border-radius: 50%;
        background: radial-gradient(circle, #172033 50%, #166534 100%);
        box-shadow: 0 0 14px rgba(34, 197, 94, 0.9), inset 0 0 12px rgba(34, 197, 94, 0.35);
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        pointer-events: none;
        z-index: 11;
        padding: 3px;
    }


    .ml-chart:hover .ml-wheel-center-glow {
        transform: translate(-50%, -50%) scale(1.1);
        box-shadow: 0 0 25px rgba(34, 197, 94, 1);
        border-color: #4ade80;
    }

    .center-title {
        color: #86efac;
        font-size: 9px;
        font-weight: 800;
        line-height: 1;
        text-transform: uppercase;
    }

    .center-sub {
        color: #ffffff;
        font-size: 7px;
        font-weight: 700;
        line-height: 1.2;
        margin-top: 2px;
    }
</style>


<style>
    /* ==========================================
               SAFE POSITION CHANGE:
               Moves graph + bonus wheel left visually only.
               Does NOT change dashboard/card dimensions.
               ========================================== */
    @@media (min-width: 900px) {
        .ml-panel-body .ml-chart {
            transform: translateX(-90px) !important;
        }
    }

    /* ==========================================
               BONUS WHEEL:
               Original size: 150px
               New size: 188px (about 25% larger)
               ========================================== */
    #bonusWheelSvg {
        width: 188px !important;
        height: 188px !important;
    }

    /* Keep the wheel glow visible */
    .ml-chart:hover #bonusWheelSvg {
        transform: translate(-50%, -50%) scale(1.04) !important;
    }

    /* Increase the middle bonus circle proportionally */
    .ml-wheel-center-glow {
        width: 70px !important;
        height: 70px !important;
        padding: 4px !important;
    }

    /* Make numbers 1 - 12 larger and clearer */
    .ml-wheel-text {
        font-size: 13px !important;
        stroke-width: 2.5px !important;
    }

    /* Make centre wording more readable */
    .center-title {
        font-size: 11px !important;
    }

    .center-sub {
        font-size: 8px !important;
    }
</style>

<style>
    /* Wheel segments now work like clickable buttons */
    .ml-wheel-slice {
        cursor: pointer;
    }

        .ml-wheel-slice:focus {
            stroke: #bbf7d0 !important;
            stroke-width: 3px !important;
            outline: none;
        }

    /* Customer details popup */
    .bonus-customer-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 99999;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: rgba(4, 10, 23, 0.78);
        backdrop-filter: blur(7px);
    }

        .bonus-customer-modal.is-open {
            display: flex;
        }

    .bonus-customer-dialog {
        position: relative;
        width: min(470px, 100%);
        max-height: calc(100vh - 40px);
        overflow-y: auto;
        border: 1px solid rgba(74, 222, 128, 0.65);
        border-radius: 20px;
        padding: 28px;
        color: white;
        background: radial-gradient(circle at top right, rgba(34, 197, 94, 0.20), transparent 40%), linear-gradient(145deg, #17233f, #0d1528);
        box-shadow: 0 0 30px rgba(34, 197, 94, 0.35), 0 25px 70px rgba(0, 0, 0, 0.55);
        animation: bonusPop 0.25s ease;
    }

    @@keyframes bonusPop {
        from {
            opacity: 0;
            transform: scale(0.90) translateY(12px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    .bonus-customer-close {
        position: absolute;
        top: 12px;
        right: 14px;
        width: 34px;
        height: 34px;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 50%;
        color: white;
        background: rgba(255, 255, 255, 0.10);
        cursor: pointer;
        font-size: 25px;
        line-height: 28px;
    }

        .bonus-customer-close:hover {
            background: #dc2626;
            border-color: #ef4444;
        }

    .bonus-customer-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding-right: 35px;
    }

    .bonus-customer-rank {
        width: 56px;
        height: 56px;
        border: 2px solid #86efac;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #dcfce7;
        background: linear-gradient(135deg, #15803d, #166534);
        box-shadow: 0 0 16px rgba(74, 222, 128, 0.45);
        font-size: 20px;
        font-weight: 800;
    }

    .bonus-customer-label {
        margin: 0 0 4px;
        color: #86efac;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .bonus-customer-header h2 {
        margin: 0;
        color: white;
        font-size: 21px;
        overflow-wrap: anywhere;
    }

    .bonus-customer-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 22px 0 18px;
        padding: 16px;
        border: 1px solid rgba(74, 222, 128, 0.35);
        border-radius: 13px;
        background: rgba(0, 0, 0, 0.18);
    }

        .bonus-customer-total span {
            color: #cbd5e1;
            font-size: 13px;
            font-weight: 600;
        }

        .bonus-customer-total strong {
            color: #86efac;
            font-size: 24px;
        }

    .bonus-customer-details-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .bonus-detail-item {
        min-height: 68px;
        padding: 12px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
    }

        .bonus-detail-item span {
            display: block;
            color: #94a3b8;
            font-size: 11px;
            margin-bottom: 6px;
        }

        .bonus-detail-item strong {
            color: #ffffff;
            font-size: 14px;
            overflow-wrap: anywhere;
        }

    .bonus-contact-section {
        margin-top: 18px;
        padding-top: 18px;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

        .bonus-contact-section h3 {
            margin: 0 0 10px;
            color: #86efac;
            font-size: 14px;
        }

    .bonus-contact-row {
        display: flex;
        justify-content: space-between;
        gap: 15px;
        padding: 10px 0;
        border-bottom: 1px dashed rgba(255, 255, 255, 0.12);
    }

        .bonus-contact-row span {
            flex-shrink: 0;
            color: #94a3b8;
            font-size: 12px;
        }

        .bonus-contact-row strong {
            color: #ffffff;
            text-align: right;
            font-size: 12px;
            overflow-wrap: anywhere;
        }

    .bonus-customer-done {
        width: 100%;
        margin-top: 20px;
        padding: 12px;
        border: none;
        border-radius: 10px;
        color: #052e16;
        background: linear-gradient(135deg, #86efac, #22c55e);
        box-shadow: 0 0 18px rgba(34, 197, 94, 0.35);
        cursor: pointer;
        font-weight: 800;
        letter-spacing: 0.5px;
    }

        .bonus-customer-done:hover {
            transform: translateY(-1px);
            box-shadow: 0 0 24px rgba(34, 197, 94, 0.55);
        }
</style>

<!-- ============================================================
     ✨ NEW: GLOWING BUTTON STYLES (replaces old .ml-cards look)
     ============================================================ -->
<style>
    .ml-buttons {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    @@media (max-width: 900px) {
        .ml-buttons {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 500px) {
        .ml-buttons {
            grid-template-columns: 1fr;
        }
    }

    .ml-btn {
        position: relative;
        border: none;
        border-radius: 18px;
        padding: 22px 20px;
        cursor: pointer;
        color: white;
        font-family: inherit;
        text-align: left;
        overflow: hidden;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        animation: mlPulse 3s ease-in-out infinite;
    }

        .ml-btn:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 15px 40px rgba(0,0,0,0.4);
        }

        .ml-btn:active {
            transform: translateY(-2px) scale(0.99);
        }

        .ml-btn::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.4s;
            pointer-events: none;
        }

        .ml-btn:hover::before {
            opacity: 1;
        }

    .ml-btn-head {
        font-size: 15px;
        font-weight: 600;
        opacity: 0.95;
        margin-bottom: 10px;
    }

    .ml-btn-value {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -0.5px;
        margin-bottom: 8px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.3);
    }

    .ml-btn-hint {
        font-size: 11px;
        opacity: 0.85;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .ml-btn-green {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        box-shadow: 0 8px 25px rgba(16, 185, 129, 0.5);
    }

    .ml-btn-red {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.5);
    }

    .ml-btn-blue {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        box-shadow: 0 8px 25px rgba(59, 130, 246, 0.5);
    }

    .ml-btn-purple {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        box-shadow: 0 8px 25px rgba(139, 92, 246, 0.5);
    }

    @@keyframes mlPulse {
        0%, 100% {
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        50% {
            box-shadow: 0 12px 35px rgba(255,255,255,0.15), 0 8px 25px rgba(0,0,0,0.3);
        }
    }

    /* ===== NEW MODAL POPUP STYLES ===== */
    .ml-modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.75);
        z-index: 99999;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(5px);
        padding: 20px;
    }

        .ml-modal-overlay.active {
            display: flex;
        }

    .ml-modal {
        background: #1e293b;
        color: white;
        width: 100%;
        max-width: 650px;
        max-height: 85vh;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0,0,0,0.6);
        animation: mlSlideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    @@keyframes mlSlideUp {
        from {
            transform: translateY(50px) scale(0.9);
            opacity: 0;
        }

        to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
    }

    .ml-modal-header {
        padding: 20px 25px;
        background: linear-gradient(135deg, #334155, #1e293b);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

        .ml-modal-header h3 {
            margin: 0;
            font-size: 20px;
            font-weight: 700;
        }

    .ml-modal-close {
        background: rgba(255,255,255,0.1);
        border: none;
        color: white;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        font-size: 22px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .ml-modal-close:hover {
            background: rgba(239, 68, 68, 0.8);
            transform: rotate(90deg);
        }

    .ml-modal-body {
        padding: 25px;
        overflow-y: auto;
        flex: 1;
    }

    .ml-loading {
        text-align: center;
        padding: 40px;
        opacity: 0.7;
    }

    .ml-sale-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 14px;
        transition: all 0.2s;
    }

        .ml-sale-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(139, 92, 246, 0.5);
        }

    .ml-sale-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
        gap: 10px;
    }

    .ml-sale-name {
        font-weight: 700;
        font-size: 16px;
    }

    .ml-sale-amount {
        color: #10b981;
        font-weight: 800;
        font-size: 18px;
        white-space: nowrap;
    }

    .ml-sale-meta {
        font-size: 12px;
        opacity: 0.7;
        margin-bottom: 8px;
    }

    .ml-sale-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 12px;
        background: rgba(139, 92, 246, 0.3);
        font-size: 11px;
        text-transform: uppercase;
        margin-left: 8px;
    }

    .ml-sale-items {
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px dashed rgba(255,255,255,0.15);
    }

    .ml-sale-item-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        padding: 4px 0;
        opacity: 0.9;
        gap: 10px;
    }

    .ml-no-items {
        font-size: 12px;
        opacity: 0.5;
        font-style: italic;
        margin-top: 8px;
    }

    .ml-breakdown-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
    }

    .ml-breakdown-item {
        background: rgba(255,255,255,0.05);
        padding: 18px;
        border-radius: 12px;
        text-align: center;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .ml-breakdown-label {
        font-size: 12px;
        text-transform: uppercase;
        opacity: 0.7;
        margin-bottom: 8px;
        letter-spacing: 1px;
    }

    .ml-breakdown-value {
        font-size: 22px;
        font-weight: 800;
        color: #10b981;
    }

    .ml-date-picker-wrap {
        text-align: center;
        padding: 20px 0;
    }

        .ml-date-picker-wrap label {
            display: block;
            margin-bottom: 12px;
            font-size: 14px;
            opacity: 0.8;
        }

        .ml-date-picker-wrap input[type="date"] {
            padding: 12px 20px;
            font-size: 16px;
            border-radius: 10px;
            border: 2px solid rgba(139, 92, 246, 0.5);
            background: rgba(255,255,255,0.1);
            color: white;
            font-family: inherit;
            cursor: pointer;
        }

            .ml-date-picker-wrap input[type="date"]:focus {
                outline: none;
                border-color: #8b5cf6;
                box-shadow: 0 0 15px rgba(139, 92, 246, 0.5);
            }

    .ml-daily-summary {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        padding: 15px;
        border-radius: 12px;
        margin: 15px 0;
        text-align: center;
    }

        .ml-daily-summary strong {
            font-size: 24px;
            display: block;
            margin-top: 5px;
        }
</style>


<!-- ============================================================
     ✨ NEW: GLOWING BUTTONS (replaces old .ml-cards section)
     ============================================================ -->
<section class="ml-buttons">

    <button type="button" class="ml-btn ml-btn-green" onclick="openHighestModal()">
        <div class="ml-btn-head">
            <span>Highest Sales</span>
        </div>
        <div class="ml-btn-value">₦@Model.HighestSale.ToString("N0")</div>
        <div class="ml-btn-hint">Click to view top 5</div>
    </button>

    <button type="button" class="ml-btn ml-btn-red" onclick="openLowestModal()">
        <div class="ml-btn-head">
            <span>Lowest Sales</span>
        </div>
        <div class="ml-btn-value">₦@Model.LowestSale.ToString("N0")</div>
        <div class="ml-btn-hint">Click to view bottom 5</div>
    </button>

    <button type="button" class="ml-btn ml-btn-blue" onclick="openTotalModal()">
        <div class="ml-btn-head">
            <span>Total Sales</span>
        </div>
        <div class="ml-btn-value">₦@Model.TotalSales.ToString("N0")</div>
        <div class="ml-btn-hint">Click for breakdown</div>
    </button>

    <button type="button" class="ml-btn ml-btn-purple" onclick="openDailyModal()">
        <div class="ml-btn-head">
            <span>Daily Sales</span>
        </div>
        <div class="ml-btn-value">Pick a Date</div>
        <div class="ml-btn-hint">Click to choose date</div>
    </button>

</section>

<!-- ============================================================
     ✨ NEW: MODAL POPUP (used by all 4 buttons above)
     ============================================================ -->
<div id="mlModalOverlay" class="ml-modal-overlay" onclick="closeMlModal(event)">
    <div class="ml-modal" onclick="event.stopPropagation()">
        <div class="ml-modal-header">
            <h3 id="mlModalTitle">Title</h3>
            <button type="button" class="ml-modal-close" onclick="closeMlModal()">×</button>
        </div>
        <div class="ml-modal-body" id="mlModalBody">
            <div class="ml-loading">Loading...</div>
        </div>
    </div>
</div>


<section class="ml-panel">
    <div class="ml-panel-header">
        <h2>Recent Sales</h2>
    </div>

    <div class="ml-panel-body">
        <div class="ml-sales-list">
            @foreach (var sale in Model.RecentSales)
            {
                var initials = string.Join("", sale.CustomerName.Split(' ', System.StringSplitOptions.RemoveEmptyEntries)
                    .Select(w => w[0])).ToUpper();
                var isToday = sale.SaleDate.Date == System.DateTime.Today || sale.SaleDate.Date == new System.DateTime(2026, 7, 15);
                <div class="ml-sale-row">
                    <span class="ml-dot"></span>
                    <div class="ml-avatar">@initials</div>
                    <div class="ml-sale-name">@sale.CustomerName</div>
                    <div class="ml-sale-amount">₦@sale.Amount.ToString("N0")</div>
                    <div class="ml-sale-when">@(isToday ? "Today" : "Yesterday")</div>
                </div>
            }
        </div>

        <div class="ml-chart">
            <!-- Your original SVG graph is completely preserved -->
            <svg viewBox="0 0 320 160" preserveAspectRatio="none">
                <g class="ml-grid">
                    @for (int i = 0; i <= 4; i++)
                    {
                        <line x1="0" y1="@(i * 32)" x2="320" y2="@(i * 32)" />
                    }
                    @for (int i = 0; i <= 8; i++)
                    {
                        <line x1="@(i * 40)" y1="0" x2="@(i * 40)" y2="160" />
                    }
                </g>
                <polyline class="ml-trend-line" fill="none"
                          points="0,120 40,90 80,140 120,110 160,95 200,100 240,70 280,40 320,15" />
                @{
                    var pts = new[] { new[] { 0, 120 }, new[] { 40, 90 }, new[] { 80, 140 }, new[] { 120, 110 }, new[] { 160, 95 }, new[] { 200, 100 }, new[] { 240, 70 }, new[] { 280, 40 }, new[] { 320, 15 } };
                }
                @foreach (var p in pts)
                {
                    <circle class="ml-trend-dot" cx="@p[0]" cy="@p[1]" r="3.5" />
                }
            </svg>

            <!-- ✨ New Glowing Watermark Pie Chart (Bonus Wheel) Overlay -->
            <div class="ml-bonus-wheel-overlay">
                <svg id="bonusWheelSvg" viewBox="0 0 320 160"></svg>
                <div class="ml-wheel-center-glow" id="wheelCenter">
                    <div class="center-title">BONUS</div>
                    <div class="center-sub">TOP 12</div>
                </div>
            </div>
        </div>
    </div>

    <div class="ml-panel-footer">
        <a href="/Sales/Create" class="ml-go-btn">GO&nbsp;TO&nbsp;SALE</a>
    </div>
</section>

<!-- BONUS WHEEL CUSTOMER DETAILS MODAL -->
<div id="bonusCustomerModal" class="bonus-customer-modal" aria-hidden="true">
    <div class="bonus-customer-dialog"
         role="dialog"
         aria-modal="true"
         aria-labelledby="bonusCustomerName">

        <button type="button"
                id="bonusCustomerClose"
                class="bonus-customer-close"
                aria-label="Close customer details">
            ×
        </button>

        <div class="bonus-customer-header">
            <div class="bonus-customer-rank" id="bonusCustomerRank">#1</div>

            <div>
                <p class="bonus-customer-label">YEARLY BONUS CUSTOMER</p>
                <h2 id="bonusCustomerName">Customer Name</h2>
            </div>
        </div>

