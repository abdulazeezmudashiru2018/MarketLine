<!-- Trigonometric SVG Builder Script -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const topCustomers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopCustomers));

        const svg = document.getElementById("bonusWheelSvg");
        const center = document.getElementById("wheelCenter");

        const modal = document.getElementById("bonusCustomerModal");
        const closeButton = document.getElementById("bonusCustomerClose");
        const doneButton = document.getElementById("bonusCustomerDone");

        if (!svg || !center || !modal) return;

        svg.setAttribute("viewBox", "0 0 200 200");

        const cx = 100;
        const cy = 100;
        const outerRadius = 90;
        const innerRadius = 38;

        function formatMoney(value) {
            return "₦" + Number(value || 0).toLocaleString("en-NG", {
                maximumFractionDigits: 0
            });
        }

        function formatDate(value) {
            if (!value) return "Not available";

            const date = new Date(value);

            if (isNaN(date.getTime())) {
                return "Not available";
            }

            return date.toLocaleString("en-NG", {
                year: "numeric",
                month: "short",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        function setCenterDefault() {
            center.replaceChildren();

            const title = document.createElement("div");
            title.className = "center-title";
            title.textContent = "BONUS";

            const sub = document.createElement("div");
            sub.className = "center-sub";
            sub.textContent = "TOP 12";

            center.append(title, sub);
        }

        function setCenterDetails(customer, rank) {
            center.replaceChildren();

            const customerName = customer.Name || "Empty Slot";
            const shortName = customerName.length > 9
                ? customerName.substring(0, 9) + "..."
                : customerName;

            const rankText = document.createElement("div");
            rankText.className = "center-title";
            rankText.textContent = "#" + rank;

            const nameText = document.createElement("div");
            nameText.style.fontSize = "8px";
            nameText.style.fontWeight = "800";
            nameText.style.color = "#ffffff";
            nameText.style.maxWidth = "64px";
            nameText.style.overflow = "hidden";
            nameText.style.textOverflow = "ellipsis";
            nameText.style.whiteSpace = "nowrap";
            nameText.style.margin = "3px 0";
            nameText.textContent = shortName;

            const amountText = document.createElement("div");
            amountText.style.fontSize = "9px";
            amountText.style.fontWeight = "800";
            amountText.style.color = "#86efac";
            amountText.textContent = formatMoney(customer.TotalSpent);

            center.append(rankText, nameText, amountText);
        }

        function openCustomerModal(customer, rank) {
            const hasCustomer = customer && customer.Name && customer.TotalSpent > 0;

            document.getElementById("bonusCustomerRank").textContent = "#" + rank;
            document.getElementById("bonusCustomerName").textContent =
                hasCustomer ? customer.Name : "No Customer Yet";

            document.getElementById("bonusCustomerTotal").textContent =
                hasCustomer ? formatMoney(customer.TotalSpent) : "₦0";

            document.getElementById("bonusPurchaseCount").textContent =
                hasCustomer ? customer.PurchaseCount : "0";

            document.getElementById("bonusLatestSource").textContent =
                hasCustomer ? customer.LatestPurchaseSource : "Not available";

            document.getElementById("bonusShopCount").textContent =
                hasCustomer ? customer.ShopPurchaseCount : "0";

            document.getElementById("bonusShopTotal").textContent =
                hasCustomer ? formatMoney(customer.ShopPurchaseTotal) : "₦0";

            document.getElementById("bonusOnlineCount").textContent =
                hasCustomer ? customer.OnlineOrderCount : "0";

            document.getElementById("bonusOnlineTotal").textContent =
                hasCustomer ? formatMoney(customer.OnlineOrderTotal) : "₦0";

            document.getElementById("bonusCustomerEmail").textContent =
                hasCustomer ? customer.Email : "Not available";

            document.getElementById("bonusCustomerAddress").textContent =
                hasCustomer ? customer.ShippingAddress : "Not available";

            document.getElementById("bonusCustomerCity").textContent =
                hasCustomer ? customer.City : "Not available";

            document.getElementById("bonusCustomerPaymentMethod").textContent =
                hasCustomer ? customer.PaymentMethod : "Not available";

            document.getElementById("bonusLastPurchaseDate").textContent =
                hasCustomer ? formatDate(customer.LastPurchaseDate) : "Not available";

            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
        }

        function closeCustomerModal() {
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
        }

        closeButton.addEventListener("click", closeCustomerModal);
        doneButton.addEventListener("click", closeCustomerModal);

        modal.addEventListener("click", function (event) {
            if (event.target === modal) {
                closeCustomerModal();
            }
        });

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape" && modal.classList.contains("is-open")) {
                closeCustomerModal();
            }
        });

        for (let i = 0; i < 12; i++) {
            const customer = topCustomers[i] || {
                Name: "Empty Slot",
                TotalSpent: 0,
                PurchaseCount: 0,
                ShopPurchaseCount: 0,
                ShopPurchaseTotal: 0,
                OnlineOrderCount: 0,
                OnlineOrderTotal: 0,
                LatestPurchaseSource: "Not available",
                Email: "Not available",
                ShippingAddress: "Not available",
                City: "Not available",
                PaymentMethod: "Not available",
                LastPurchaseDate: null
            };

            const startAngle = (i * 30) - 90;
            const endAngle = ((i + 1) * 30) - 90;

            const rad1 = (startAngle * Math.PI) / 180;
            const rad2 = (endAngle * Math.PI) / 180;

            const x1 = cx + outerRadius * Math.cos(rad1);
            const y1 = cy + outerRadius * Math.sin(rad1);
            const x2 = cx + outerRadius * Math.cos(rad2);
            const y2 = cy + outerRadius * Math.sin(rad2);

            const xi1 = cx + innerRadius * Math.cos(rad1);
            const yi1 = cy + innerRadius * Math.sin(rad1);
            const xi2 = cx + innerRadius * Math.cos(rad2);
            const yi2 = cy + innerRadius * Math.sin(rad2);

            const pathData = `
                M ${xi1} ${yi1}
                L ${x1} ${y1}
                A ${outerRadius} ${outerRadius} 0 0 1 ${x2} ${y2}
                L ${xi2} ${yi2}
                A ${innerRadius} ${innerRadius} 0 0 0 ${xi1} ${yi1}
                Z
            `;

            const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
            path.setAttribute("d", pathData);
            path.setAttribute("class", "ml-wheel-slice");

            /* Makes each SVG portion behave like a button */
            path.setAttribute("role", "button");
            path.setAttribute("tabindex", "0");
            path.setAttribute(
                "aria-label",
                `Bonus rank ${i + 1}: ${customer.Name}, ${formatMoney(customer.TotalSpent)}`
            );

            path.style.fill = i % 2 === 0
                ? "rgba(12, 17, 30, 0.92)"
                : "rgba(22, 40, 65, 0.90)";

            const title = document.createElementNS("http://www.w3.org/2000/svg", "title");
            title.textContent = `#${i + 1} - ${customer.Name} - ${formatMoney(customer.TotalSpent)}`;
            path.appendChild(title);

            const labelAngle = startAngle + 15;
            const labelRadians = (labelAngle * Math.PI) / 180;
            const labelRadius = innerRadius + ((outerRadius - innerRadius) / 2);

            const labelX = cx + labelRadius * Math.cos(labelRadians);
            const labelY = cy + labelRadius * Math.sin(labelRadians);

            const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
            text.setAttribute("x", labelX);
            text.setAttribute("y", labelY);
            text.setAttribute("class", "ml-wheel-text");
            text.textContent = i + 1;

            path.addEventListener("mouseenter", function () {
                setCenterDetails(customer, i + 1);
            });

            path.addEventListener("mouseleave", function () {
                setCenterDefault();
            });

            path.addEventListener("click", function () {
                openCustomerModal(customer, i + 1);
            });

            path.addEventListener("keydown", function (event) {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    openCustomerModal(customer, i + 1);
                }
            });

            svg.appendChild(path);
            svg.appendChild(text);
        }

        setCenterDefault();
    });
</script>


<!-- ============================================================
     ✨ NEW: DASHBOARD BUTTON POPUP SCRIPTS
     (Highest, Lowest, Total Breakdown, Daily Sales)
     ============================================================ -->
<script>
    (function () {
        const mlOverlay = document.getElementById('mlModalOverlay');
        const mlTitle = document.getElementById('mlModalTitle');
        const mlBody = document.getElementById('mlModalBody');

        function openMlModal(title) {
            mlTitle.textContent = title;
            mlBody.innerHTML = '<div class="ml-loading">⏳ Loading...</div>';
            mlOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        window.closeMlModal = function (event) {
            if (event && event.target !== mlOverlay && !event.target.classList.contains('ml-modal-close')) return;
            mlOverlay.classList.remove('active');
            document.body.style.overflow = '';
        };

        // ESC to close
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && mlOverlay.classList.contains('active')) {
                mlOverlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        function formatMoneyMl(n) {
            return '₦' + Number(n || 0).toLocaleString('en-NG', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
        }

        function formatDateMl(iso) {
            if (!iso) return '';
            const d = new Date(iso);
            if (isNaN(d.getTime())) return '';
            return d.toLocaleString('en-NG', {
                year: 'numeric', month: 'short', day: 'numeric',
                hour: '2-digit', minute: '2-digit'
            });
        }

        function renderSaleCard(sale) {
            let itemsHtml = '';
            if (sale.items && sale.items.length > 0) {
                itemsHtml = '<div class="ml-sale-items">';
                sale.items.forEach(function (item) {
                    itemsHtml +=
                        '<div class="ml-sale-item-row">' +
                        '<span>📦 ' + item.description + ' × ' + item.quantity + '</span>' +
                        '<span>' + formatMoneyMl(item.totalPrice) + '</span>' +
                        '</div>';
                });
                itemsHtml += '</div>';
            } else {
                itemsHtml = '<div class="ml-no-items">No items recorded for this sale</div>';
            }

            return (
                '<div class="ml-sale-card">' +
                    '<div class="ml-sale-top">' +
                        '<div>' +
                            '<div class="ml-sale-name">' + sale.customerName + '</div>' +
                            '<div class="ml-sale-meta">' + formatDateMl(sale.date) +
                            '<span class="ml-sale-badge">' + sale.source + '</span></div>' +
                        '</div>' +
                        '<div class="ml-sale-amount">' + formatMoneyMl(sale.amount) + '</div>' +
                    '</div>' +
                    itemsHtml +
                '</div>'
            );
        }

        // ---------- TOP 5 HIGHEST ----------
        window.openHighestModal = async function () {
            openMlModal('Top 5 Highest Sales');
            try {
                const res = await fetch('/Dashboard/GetTop5HighestSales');
                const data = await res.json();
                if (!data || data.length === 0) {
                    mlBody.innerHTML = '<div class="ml-loading">No sales yet.</div>';
                    return;
                }
                mlBody.innerHTML = data.map(renderSaleCard).join('');
            } catch (err) {
                mlBody.innerHTML = '<div class="ml-loading">❌ Failed to load. Try again.</div>';
            }
        };

        // ---------- TOP 5 LOWEST ----------
        window.openLowestModal = async function () {
            openMlModal('Top 5 Lowest Sales');
            try {
                const res = await fetch('/Dashboard/GetTop5LowestSales');
                const data = await res.json();
                if (!data || data.length === 0) {
                    mlBody.innerHTML = '<div class="ml-loading">No sales yet.</div>';
                    return;
                }
                mlBody.innerHTML = data.map(renderSaleCard).join('');
            } catch (err) {
                mlBody.innerHTML = '<div class="ml-loading">❌ Failed to load. Try again.</div>';
            }
        };

        // ---------- TOTAL SALES BREAKDOWN ----------
        window.openTotalModal = async function () {
            openMlModal('Total Sales Breakdown');
            try {
                const res = await fetch('/Dashboard/GetTotalSalesBreakdown');
                const d = await res.json();
                mlBody.innerHTML =
                    '<div class="ml-breakdown-grid">' +
                        '<div class="ml-breakdown-item">' +
                            '<div class="ml-breakdown-label">Today</div>' +
                            '<div class="ml-breakdown-value">' + formatMoneyMl(d.today) + '</div>' +
                        '</div>' +
                        '<div class="ml-breakdown-item">' +
                            '<div class="ml-breakdown-label">Yesterday</div>' +
                            '<div class="ml-breakdown-value">' + formatMoneyMl(d.yesterday) + '</div>' +
                        '</div>' +
                        '<div class="ml-breakdown-item">' +
                            '<div class="ml-breakdown-label">This Week</div>' +
                            '<div class="ml-breakdown-value">' + formatMoneyMl(d.thisWeek) + '</div>' +
                        '</div>' +
                        '<div class="ml-breakdown-item">' +
                            '<div class="ml-breakdown-label">This Month</div>' +
                            '<div class="ml-breakdown-value">' + formatMoneyMl(d.thisMonth) + '</div>' +
                        '</div>' +
                        '<div class="ml-breakdown-item">' +
                            '<div class="ml-breakdown-label">This Year</div>' +
                            '<div class="ml-breakdown-value">' + formatMoneyMl(d.thisYear) + '</div>' +
                        '</div>' +
                        '<div class="ml-breakdown-item">' +
                            '<div class="ml-breakdown-label">All Time (' + d.totalTransactions + ' txns)</div>' +
                            '<div class="ml-breakdown-value">' + formatMoneyMl(d.allTime) + '</div>' +
                        '</div>' +
                    '</div>';
            } catch (err) {
                mlBody.innerHTML = '<div class="ml-loading">❌ Failed to load. Try again.</div>';
            }
        };

        // ---------- DAILY SALES (with date picker) ----------
        window.openDailyModal = function () {
            openMlModal('Daily Sales');
            const today = new Date().toISOString().split('T')[0];
            mlBody.innerHTML =
                '<div class="ml-date-picker-wrap">' +
                    '<label>Pick a date to see all sales made on that day:</label>' +
                    '<input type="date" id="mlDatePicker" max="' + today + '" value="' + today + '" />' +
                '</div>' +
                '<div id="mlDailyResults"></div>';

            document.getElementById('mlDatePicker').addEventListener('change', function () {
                loadDailySales(this.value);
            });

            loadDailySales(today);
        };

        async function loadDailySales(date) {
            const resultsDiv = document.getElementById('mlDailyResults');
            if (!resultsDiv) return;
            resultsDiv.innerHTML = '<div class="ml-loading">⏳ Loading sales...</div>';
            try {
                const res = await fetch('/Dashboard/GetSalesByDate?date=' + date);
                const d = await res.json();
                if (!d.sales || d.sales.length === 0) {
                    resultsDiv.innerHTML =
                        '<div class="ml-daily-summary">' +
                            'No sales on ' + d.date +
                            '<strong>' + formatMoneyMl(0) + '</strong>' +
                        '</div>';
                    return;
                }
                resultsDiv.innerHTML =
                    '<div class="ml-daily-summary">' +
                        d.count + ' sale(s) on ' + d.date +
                        '<strong>' + formatMoneyMl(d.totalForDay) + '</strong>' +
                    '</div>' +
                    d.sales.map(renderSaleCard).join('');
            } catch (err) {
                resultsDiv.innerHTML = '<div class="ml-loading">❌ Failed to load. Try again.</div>';
            }
        }
    })();
</script>